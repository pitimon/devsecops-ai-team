# Demo .env.example — DevSecOps AI Team
# Shows common patterns that secret scanners should detect.
# All values are FAKE demo placeholders — not real credentials.
#
# Expected findings:
#   - GitLeaks / TruffleHog: credential-like patterns in config files

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp
DB_USER=admin
DB_PASS=change_me_in_production

# Application
APP_PORT=5000
APP_DEBUG=true
NODE_ENV=development

# External Services (demo placeholder values)
SMTP_HOST=smtp.example.com
SMTP_USER=noreply@example.com
SMTP_PASS=demo-smtp-placeholder

# Cloud Config (demo placeholder values)
CLOUD_REGION=us-east-1
CLOUD_BUCKET=my-app-uploads
CLOUD_ACCESS_ID=DEMO0000FAKE0ACCESS0
CLOUD_SECRET=demo-fake-secret-do-not-use-in-production

# Monitoring
SENTRY_DSN=https://demo0000fake@o0.ingest.sentry.io/0
LOG_LEVEL=debug
